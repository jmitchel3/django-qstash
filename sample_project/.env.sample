# Copy this file to .env and you can run the sample project fully locally
# (no Upstash account, no public domain). See README.md for the two workflows.
#
#   cp .env.sample .env
#
# The QSTASH_* values below are the fixed credentials printed by the local
# `qstash dev` server (compose.dev.yaml). They are for local development ONLY.

# --- Django ---
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=local-dev-not-secret
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# --- QStash dev server (compose.dev.yaml) ---
QSTASH_URL=http://127.0.0.1:8585
QSTASH_TOKEN=eyJVc2VySUQiOiJkZWZhdWx0VXNlciIsIlBhc3N3b3JkIjoiZGVmYXVsdFBhc3N3b3JkIn0=
QSTASH_CURRENT_SIGNING_KEY=sig_7kYjw48mhY7kAjqNGcy6cr29RJ6r
QSTASH_NEXT_SIGNING_KEY=sig_5ZB6DVzB1wjE8S6rZ7eenA8Pdnhs

# --- django-qstash ---
# The QStash dev server runs in Docker and calls back to Django on the host.
# host.docker.internal resolves to the host machine from inside the container.
# Run Django with: python manage.py runserver 0.0.0.0:8000
DJANGO_QSTASH_DOMAIN=http://host.docker.internal:8000
DJANGO_QSTASH_WEBHOOK_PATH=/qstash/webhook/
# Must be False locally so plain-http callbacks verify. Defaults to True (https)
# in production (when DJANGO_DEBUG is off).
DJANGO_QSTASH_FORCE_HTTPS=False
